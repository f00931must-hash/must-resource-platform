rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email != null;
    }
    function email() {
      return request.auth.token.email;
    }
    function adminDocExists() {
      return exists(/databases/$(database)/documents/settings/admins);
    }
    function adminData() {
      return get(/databases/$(database)/documents/settings/admins).data;
    }
    function isBuiltInSuperAdmin() {
      return signedIn() && email() in ["master004400@gmail.com"];
    }
    function isSuperAdmin() {
      return isBuiltInSuperAdmin()
        || (signedIn() && adminDocExists() && email() in adminData().superAdmins);
    }
    function isTeacher() {
      return isSuperAdmin()
        || (signedIn() && adminDocExists() && email() in adminData().teachers);
    }
    function isAssistant() {
      return signedIn() && adminDocExists() && email() in adminData().assistants;
    }
    function isAnyStaff() {
      return isSuperAdmin() || isTeacher() || isAssistant();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow create: if isTeacher() || (isAssistant() && request.resource.data.published == false);
      allow update: if isTeacher() || (isAssistant() && request.resource.data.published == false);
      allow delete: if isTeacher();
    }

    match /settings/admins {
      allow read: if isAnyStaff() || isBuiltInSuperAdmin();
      allow create, update: if isSuperAdmin() || isBuiltInSuperAdmin();
      allow delete: if false;
    }
  }
}
